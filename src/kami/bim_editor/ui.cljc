(ns kami.bim-editor.ui (:require [html.core :as html] [css.core :as css]))
(def sheet {:rules {"body" {:margin 0 :font-family "system-ui" :background "#0c1221" :color "#e7ecfa"} "header" {:padding 16 :display :flex :justify-content :space-between :background "#121c38"} "main" {:display :grid :grid-template-columns "230px 1fr 260px" :min-height "calc(100vh - 52px)"} "aside" {:padding 18 :background "#111a34" :border-right "1px solid #2d3e68"} ".plan" {:position :relative :margin 22 :border "1px solid #49618d" :background "repeating-linear-gradient(0deg,transparent,transparent 31px,#25385f 32px),repeating-linear-gradient(90deg,transparent,transparent 31px,#25385f 32px)"} ".wall" {:position :absolute :background "#87a5e5"} ".w1" {:left "16%" :top "22%" :width "65%" :height 14} ".w2" {:left "16%" :top "22%" :width 14 :height "58%"} ".w3" {:left "16%" :top "80%" :width "65%" :height 14} ".w4" {:left "81%" :top "22%" :width 14 :height "58%"} "button" {:display :block :width "100%" :margin "8px 0" :padding 10 :background "#20315b" :border "1px solid #526fa9" :border-radius 6 :color "#e7ecfa" :text-align :left} "h2" {:font-size 12 :text-transform :uppercase :letter-spacing ".1em" :color "#a7b9e0"} "dl" {:font-size 13} "dt" {:color "#9eb0d8"} "dd" {:margin "2px 0 12px"}}})
(defn page [] (html/html5 [:html [:head [:meta {:charset "utf-8"}] [:meta {:name "viewport" :content "width=device-width,initial-scale=1"}] [:title "Kami BIM Editor"] [:style (css/css sheet)]] [:body [:header [:strong "KAMI BIM EDITOR"] [:span "Lodge · Ground Floor"]] [:main [:aside [:h2 "Elements"] [:button "＋ Wall"] [:button "＋ Slab"] [:button "＋ Door"] [:button "＋ Window"] [:h2 "Levels"] [:button "Ground Floor · 0.00 m"] [:button "Level 01 · 3.20 m"]] [:section.plan [:div.wall.w1] [:div.wall.w2] [:div.wall.w3] [:div.wall.w4]] [:aside [:h2 "Selected wall"] [:dl [:dt "Type"] [:dd "Exterior Wall"] [:dt "Length"] [:dd "8.40 m"] [:dt "Height"] [:dd "3.20 m"] [:dt "Material"] [:dd "Reinforced concrete"]] [:button "Edit properties"]]]]]))
